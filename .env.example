# Copy to .env and fill in. Never commit .env.

# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# False in production, True in local dev only
DEBUG=False

# Comma-separated. In production: your-domain.com,your-app.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (Railway): DATABASE_URL is auto-injected when you add Postgres add-on.
# DATABASE_URL=postgresql://user:password@host:port/database

# Local dev: individual DB settings (used when DATABASE_URL is not set)
DB_NAME=tivano
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Media storage ---
# Production: store uploaded photos on S3 (signed URLs, private bucket).
# Local dev: leave USE_S3=False (uses ./media/).
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1
# Only for S3-compatible providers (Cloudflare R2, Backblaze B2). LEAVE EMPTY for AWS S3.
# AWS_S3_ENDPOINT_URL=
